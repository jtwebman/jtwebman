---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { projects, type Project } from '../../data/projects';
import { generateProjectStructuredData } from '../../utils/structured-data';

export function getStaticPaths() {
  return projects.map(project => ({
    params: { slug: project.slug },
    props: project,
  }));
}

type Props = Project;

const project = Astro.props;

const structuredData = generateProjectStructuredData({
  name: project.name,
  tagline: project.tagline,
  url: new URL(`/projects/${project.slug}`, Astro.site).toString(),
  liveUrl: project.liveUrl,
  sourceUrl: project.sourceUrl,
});
---

<BaseLayout
  title={`${project.name} - JT Turner`}
  description={project.tagline}
  structuredData={structuredData}
>
  <div class="flex flex-col min-h-screen">
    <Header />

    <main class="flex-grow bg-gray-50 dark:bg-gray-900">
      <section class="container mx-auto px-4 py-16">
        <div class="max-w-3xl mx-auto">
          <a
            href="/projects"
            class="inline-flex items-center gap-1 text-sm text-blue-600 dark:text-blue-400 hover:underline mb-8"
          >
            ← All projects
          </a>

          <h1 class="text-4xl font-bold text-gray-900 dark:text-gray-100 mb-3">{project.name}</h1>
          <p class="text-xl text-gray-600 dark:text-gray-400 mb-8">{project.tagline}</p>

          <div class="flex flex-wrap gap-3 mb-12">
            {
              project.liveUrl && (
                <a
                  href={project.liveUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-block bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-700 transition-colors"
                >
                  Visit {project.name} ↗
                </a>
              )
            }
            {
              project.openSource && project.sourceUrl && (
                <a
                  href={project.sourceUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class={`inline-block px-6 py-3 rounded-lg font-semibold transition-colors border ${
                    project.liveUrl
                      ? 'border-gray-300 dark:border-gray-600 text-gray-900 dark:text-gray-100 hover:bg-gray-100 dark:hover:bg-gray-800'
                      : 'bg-blue-600 text-white border-blue-600 hover:bg-blue-700'
                  }`}
                >
                  View source ↗
                </a>
              )
            }
          </div>

          <div class="space-y-8">
            <div>
              <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-4">What it does</h2>
              <div class="space-y-4">
                {
                  project.description.map(paragraph => (
                    <p class="text-gray-700 dark:text-gray-300 leading-relaxed">{paragraph}</p>
                  ))
                }
              </div>
            </div>

            <div>
              <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-4">Built with</h2>
              <ul class="flex flex-wrap gap-2">
                {
                  project.tech.map(tech => (
                    <li class="px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-full text-sm border border-gray-200 dark:border-gray-700">
                      {tech}
                    </li>
                  ))
                }
              </ul>
            </div>

            <div>
              <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-4">Source</h2>
              {
                project.openSource && project.sourceUrl ? (
                  <p class="text-gray-700 dark:text-gray-300">
                    Open source{project.license && ` under the ${project.license} license`}.{' '}
                    <a
                      href={project.sourceUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-blue-600 dark:text-blue-400 hover:underline"
                    >
                      View the code on GitHub ↗
                    </a>
                    .
                  </p>
                ) : (
                  <p class="text-gray-700 dark:text-gray-300">
                    This one is closed source. It's a commercial product.
                  </p>
                )
              }
            </div>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>
